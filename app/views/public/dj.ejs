<%- include('_header', { title }) %>
<div class="container" style="padding-top:3rem;">
  <div class="section-label">I nostri artisti</div>
  <h1 class="section-title">DJ Lineup</h1>
  <% if (djs.length === 0) { %>
    <p style="color:var(--text-muted);">Nessun profilo DJ disponibile.</p>
  <% } else { %>
    <div class="grid grid-3">
      <% djs.forEach(dj => { %>
        <div class="card dj-card">
          <% if (dj.foto_path) { %>
            <img src="/uploads/<%= dj.foto_path %>" alt="<%= dj.nome %>">
          <% } else { %>
            <div style="width:100%;aspect-ratio:1;background:var(--bg-surface);border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;border:1px solid var(--border);font-size:3rem;">🎧</div>
          <% } %>
          <h2 style="font-size:1.3rem;color:var(--neon-fuchsia);"><%= dj.nome %></h2>
          <div style="margin-top:0.5rem;line-height:1.7;"><%- dj.bio_html || '' %></div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('_footer') %>
