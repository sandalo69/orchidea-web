<%- include('_header', { title }) %>
<div class="form-card">
  <h1 class="form-title">Password dimenticata</h1>
  <% if (query.success === 'email_inviata') { %>
    <div class="alert alert-success">
      Se l'email è associata a un account, riceverai un link per reimpostare la password.
    </div>
  <% } else { %>
    <% if (query.error === 'campi_mancanti') { %>
      <div class="alert alert-error">Inserisci la tua email.</div>
    <% } %>
    <p style="color:var(--text-muted);margin-bottom:1.5rem;font-size:0.95rem;">
      Inserisci l'email del tuo account. Ti invieremo un link per reimpostare la password.
    </p>
    <form method="POST" action="/auth/password-reset">
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" required autocomplete="email">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;margin-top:0.5rem;">
        Invia link reset
      </button>
    </form>
  <% } %>
  <p style="text-align:center;margin-top:1.5rem;color:var(--text-muted);font-size:0.9rem;">
    <a href="/auth/login" style="color:var(--neon-purple);">← Torna al login</a>
  </p>
</div>
<%- include('_footer') %>
