<%- include('_header', { title }) %>
<style>
#lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:9999;align-items:center;justify-content:center;}
#lightbox.aperto{display:flex;}
#lightbox img{max-width:95vw;max-height:92vh;object-fit:contain;border-radius:4px;pointer-events:none;user-select:none;-webkit-user-drag:none;}
#lightbox-close{position:fixed;top:1rem;right:1.5rem;font-size:2.5rem;color:#fff;cursor:pointer;line-height:1;z-index:10000;}
</style>
<div id="lightbox" onclick="chiudiLightbox()">
  <span id="lightbox-close">✕</span>
  <img id="lightbox-img" src="" alt="">
</div>
<div class="container" style="padding-top:3rem;">
  <div class="section-label">Le nostre notti</div>
  <h1 class="section-title">Galleria</h1>

  <% if (eventi.length > 0) { %>
  <div style="margin-bottom:2rem;">
    <select onchange="location.href='/galleria' + (this.value ? '?evento=' + this.value : '')"
            style="background:var(--card-bg);border:1px solid var(--border);color:var(--text-primary);padding:0.6rem 1rem;border-radius:6px;font-size:0.95rem;cursor:pointer;">
      <option value="" <%= !eventoSelezionato ? 'selected' : '' %>>Tutte le foto</option>
      <% eventi.forEach(ev => { %>
        <option value="<%= ev.id %>" <%= eventoSelezionato == ev.id ? 'selected' : '' %>><%= ev.titolo %></option>
      <% }) %>
    </select>
  </div>
  <% } %>

  <% if (foto.length === 0) { %>
    <p style="color:var(--text-muted);">Nessuna foto disponibile.</p>
  <% } else { %>
    <div class="gallery-grid">
      <% foto.forEach(f => { %>
        <div class="gallery-item">
          <img src="/uploads/<%= f.foto_path %>" alt="<%= f.didascalia || '' %>"
               draggable="false" style="-webkit-user-drag:none;cursor:pointer;"
               onclick="apriLightbox(this.src)">
          <% if (f.didascalia || f.evento_titolo) { %>
            <p style="margin-top:0.4rem;font-size:0.8rem;color:var(--text-muted);">
              <%= f.didascalia || '' %><% if (f.evento_titolo) { %> — <%= f.evento_titolo %><% } %>
            </p>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<script>
  function apriLightbox(src) {
    document.getElementById('lightbox-img').src = src;
    document.getElementById('lightbox').classList.add('aperto');
    document.body.style.overflow = 'hidden';
  }
  function chiudiLightbox() {
    document.getElementById('lightbox').classList.remove('aperto');
    document.getElementById('lightbox-img').src = '';
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') chiudiLightbox(); });
  document.addEventListener('contextmenu', e => { if (e.target.tagName === 'IMG') e.preventDefault(); });
</script>
<%- include('_footer') %>
