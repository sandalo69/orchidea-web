<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= locals.title ? locals.title + ' — ' : '' %>Orchidea</title>
  <meta name="description" content="<%= locals.metaDescription || 'Orchidea Disco — Rottanova (VE). Prenota i tuoi posti per le nostre serate, venerdì e sabato dalle 23:00.' %>">
  <meta property="og:title" content="<%= locals.title ? locals.title + ' — ' : '' %>Orchidea">
  <meta property="og:description" content="<%= locals.metaDescription || 'Orchidea Disco — Rottanova (VE). Prenota i tuoi posti per le nostre serate, venerdì e sabato dalle 23:00.' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= (process.env.BASE_URL || 'https://orchidea.it') + (locals.ogPath || '/') %>">
  <link rel="icon" type="image/jpeg" href="/img/logo.jpeg">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="main-nav">
  <a href="/" class="logo"><img src="/img/logo.jpeg" alt="Orchidea" style="height:40px;vertical-align:middle;"></a>
  <button id="nav-toggle" class="nav-toggle" aria-label="Menu">☰</button>
  <div class="nav-links" id="nav-links">
    <a href="/eventi">Eventi</a>
    <a href="/dj">DJ</a>
    <a href="/galleria">Galleria</a>
    <a href="/news">News</a>
    <a href="/contatti">Contatti</a>
    <% if (locals.user) { %>
      <a href="/account">Account</a>
      <a href="/prenota">Prenota</a>
      <form method="POST" action="/auth/logout" style="display:inline;">
        <button type="submit" class="btn-logout">Esci (<%= locals.user.nome %>)</button>
      </form>
    <% } else { %>
      <a href="/auth/login" class="btn-nav">Accedi</a>
    <% } %>
  </div>
</nav>
<main>
