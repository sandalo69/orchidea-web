<%- include('_header', { title }) %>
<div class="form-card">
  <h1 class="form-title">Nuova password</h1>
  <% if (!valid) { %>
    <div class="alert alert-error">
      Il link è scaduto o non è valido. <a href="/auth/password-reset" style="color:var(--neon-cyan);">Richiedi un nuovo link</a>.
    </div>
  <% } else { %>
    <% if (query && query.error === 'password_corta') { %>
      <div class="alert alert-error">La password deve avere almeno 8 caratteri.</div>
    <% } %>
    <p style="color:var(--text-muted);margin-bottom:1.5rem;font-size:0.95rem;">
      Scegli una nuova password per il tuo account.
    </p>
    <form method="POST" action="/auth/nuova-password">
      <input type="hidden" name="token" value="<%= token %>">
      <div class="form-group">
        <label>Nuova password (min 8 caratteri)</label>
        <input type="password" name="password" required minlength="8" autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;margin-top:0.5rem;">
        Salva nuova password
      </button>
    </form>
  <% } %>
</div>
<%- include('_footer') %>
