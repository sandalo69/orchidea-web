<%- include('_header', { title }) %>
<div style="text-align:center;padding:5rem 2rem;max-width:600px;margin:0 auto;">
  <div style="font-size:4rem;margin-bottom:1rem;">🎉</div>
  <h1 style="font-size:2rem;font-weight:900;color:var(--neon-cyan);margin-bottom:1rem;">Prenotazione confermata!</h1>
  <% if (booking) { %>
    <div class="card" style="text-align:left;margin:2rem 0;">
      <p><strong>Evento:</strong> <%= booking.evento_titolo %></p>
      <p><strong>Data:</strong> <%= new Date(booking.data_evento).toLocaleDateString('it-IT', {weekday:'long',day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></p>
      <p><strong>Importo pagato:</strong> €<%= parseFloat(booking.importo).toFixed(2) %></p>
      <p><strong>Riferimento:</strong> #<%= booking.id %></p>
    </div>
    <p style="color:var(--text-muted);margin-bottom:2rem;">Riceverai una email di conferma all'indirizzo registrato.</p>
  <% } %>
  <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
    <a href="/prenota/mie" class="btn btn-primary">Le mie prenotazioni</a>
    <a href="/eventi" class="btn btn-secondary">Altri eventi</a>
  </div>
</div>
<%- include('_footer') %>
