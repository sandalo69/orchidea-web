<%- include('_header', { title }) %>
<div class="hero">
  <h1>Benvenuto all'Orchidea</h1>
  <p>La discoteca più esclusiva della città. Musica, atmosfera e notti indimenticabili.</p>
  <a href="/eventi" class="btn btn-primary">Scopri gli eventi</a>
</div>

<section class="section">
  <div class="container">
    <div class="section-label">Prossimi appuntamenti</div>
    <h2 class="section-title">Serate in arrivo</h2>
    <% if (eventi.length === 0) { %>
      <p style="color:var(--text-muted);">Nessun evento in programma al momento.</p>
    <% } else { %>
      <div class="grid grid-3">
        <% eventi.forEach(ev => { %>
          <a href="/eventi/<%= ev.id %>" class="card" style="display:block;">
            <div class="card-label"><%= new Date(ev.data_evento).toLocaleDateString('it-IT', {weekday:'long',day:'numeric',month:'long'}) %></div>
            <h3><%= ev.titolo %></h3>
            <p><%= ev.descrizione ? ev.descrizione.substring(0,120) + '...' : '' %></p>
            <p style="margin-top:1rem;color:var(--neon-cyan);">Acconto: €<%= ev.costo_acconto %>/posto</p>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<% if (news.length > 0) { %>
<section class="section" style="padding-top:0;">
  <div class="container">
    <div class="section-label">Aggiornamenti</div>
    <h2 class="section-title">News</h2>
    <div class="grid grid-3">
      <% news.forEach(n => { %>
        <div class="card">
          <div class="card-label"><%= new Date(n.created_at).toLocaleDateString('it-IT') %></div>
          <h3><%= n.titolo %></h3>
          <p><%= n.contenuto.substring(0,150) %></p>
        </div>
      <% }) %>
    </div>
    <div style="text-align:center;margin-top:1.5rem;">
      <a href="/news" class="btn btn-secondary">Tutte le news &rarr;</a>
    </div>
  </div>
</section>
<% } %>

<section class="section" style="padding-top:0;">
  <div class="container" style="max-width:600px;text-align:center;">
    <div class="section-label">Resta aggiornato</div>
    <h2 class="section-title">Newsletter</h2>
    <p style="color:var(--text-muted);margin-bottom:2rem;">Ricevi in anteprima le date delle nostre serate.</p>
    <% if (locals.newsletter === 'ok') { %>
      <div class="alert-success" style="margin-bottom:1rem;">Iscritto! A presto.</div>
    <% } %>
    <% if (locals.newsletter === 'error') { %>
      <div class="alert-error" style="margin-bottom:1rem;">Email non valida.</div>
    <% } %>
    <form method="POST" action="/newsletter/subscribe"
          style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
      <input type="email" name="email" placeholder="La tua email" required
             style="flex:1;min-width:200px;max-width:300px;">
      <button type="submit" class="btn btn-primary">Iscriviti</button>
    </form>
  </div>
</section>
<%- include('_footer') %>
