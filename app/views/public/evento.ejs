<%- include('_header', { title }) %>
<div class="container" style="padding-top:3rem;max-width:800px;">
  <a href="/eventi" style="color:var(--text-muted);font-size:0.9rem;">← Tutti gli eventi</a>
  <div style="margin-top:2rem;">
    <div class="card-label">
      <%= new Date(evento.data_evento).toLocaleDateString('it-IT', {weekday:'long',day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
    </div>
    <h1 style="font-size:2.5rem;font-weight:900;margin:0.5rem 0;"><%= evento.titolo %></h1>
    <% if (evento.prenotazioni_aperte) { %>
      <span class="badge badge-green" style="margin-bottom:1.5rem;display:inline-block;">Prenotazioni aperte</span>
    <% } else { %>
      <span class="badge badge-gray" style="margin-bottom:1.5rem;display:inline-block;">Prenotazioni chiuse</span>
    <% } %>
    <p style="line-height:1.8;color:var(--text-muted);font-size:1.05rem;margin-bottom:2rem;"><%= evento.descrizione || '' %></p>
    <div class="card" style="display:inline-block;margin-bottom:2rem;">
      <p>Acconto per posto: <strong style="color:var(--neon-cyan);">€<%= evento.costo_acconto %></strong></p>
      <p>Max posti per utente: <strong><%= evento.max_posti_per_utente %></strong></p>
    </div>
    <% if (evento.prenotazioni_aperte) { %>
      <div>
        <% if (locals.user) { %>
          <a href="/prenota/<%= evento.id %>" class="btn btn-primary">Prenota ora</a>
        <% } else { %>
          <a href="/auth/login" class="btn btn-primary">Accedi per prenotare</a>
        <% } %>
      </div>
    <% } %>
  </div>
  <% if (foto && foto.length > 0) { %>
  <style>
    #lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.95);z-index:9999;align-items:center;justify-content:center;}
    #lightbox.aperto{display:flex;}
    #lightbox-img{width:90vw;height:88vh;background-size:contain;background-repeat:no-repeat;background-position:center;}
    #lightbox-close{position:fixed;top:1rem;right:1.5rem;font-size:2.5rem;color:#fff;cursor:pointer;line-height:1;z-index:10000;user-select:none;}
    .gallery-thumb{width:100%;aspect-ratio:4/3;background-size:cover;background-position:center;border-radius:6px;cursor:pointer;}
  </style>
  <div id="lightbox" onclick="chiudiLightbox()">
    <span id="lightbox-close">✕</span>
    <div id="lightbox-img"></div>
  </div>
  <div style="margin-top:3rem;">
    <div class="section-label">Fotografie</div>
    <h2 class="section-title" style="font-size:1.5rem;">Gallery serata</h2>
    <div class="gallery-grid">
      <% foto.forEach(f => { %>
        <div class="gallery-item">
          <div class="gallery-thumb"
               style="background-image:url('/uploads/<%= f.foto_path %>');"
               onclick="apriLightbox('/uploads/<%= f.foto_path %>')"></div>
        </div>
      <% }) %>
    </div>
  </div>
  <script>
    function apriLightbox(src) {
      document.getElementById('lightbox-img').style.backgroundImage = "url('" + src + "')";
      document.getElementById('lightbox').classList.add('aperto');
      document.body.style.overflow = 'hidden';
    }
    function chiudiLightbox() {
      document.getElementById('lightbox').classList.remove('aperto');
      document.getElementById('lightbox-img').style.backgroundImage = '';
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') chiudiLightbox(); });
    document.addEventListener('contextmenu', e => e.preventDefault());
  </script>
  <% } %>
</div>
<%- include('_footer') %>
