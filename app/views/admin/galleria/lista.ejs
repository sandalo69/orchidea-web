<%- include('../_header', { title, active }) %>
<div class="page-header">
  <h1>Galleria</h1>
  <a href="/admin/galleria/nuovo" class="btn btn-primary">+ Aggiungi foto</a>
</div>
<% if (foto.length === 0) { %>
  <p style="color:var(--text-muted);">Nessuna foto. <a href="/admin/galleria/nuovo" style="color:var(--neon-purple);">Aggiungine una</a></p>
<% } else { %>
<form method="POST" action="/admin/galleria/elimina-bulk" id="bulk-form">
  <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
    <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
      <input type="checkbox" id="seleziona-tutto" style="width:auto;">
      <span style="font-size:0.9rem;">Seleziona tutte</span>
    </label>
    <button type="submit" class="btn btn-sm btn-danger" id="btn-elimina-sel"
            style="display:none;"
            onclick="return confirm('Eliminare le foto selezionate?')">
      Elimina selezionate
    </button>
  </div>
  <div class="gallery-grid">
    <% foto.forEach(f => { %>
      <div style="position:relative;">
        <input type="checkbox" name="ids" value="<%= f.id %>" class="foto-cb"
               style="position:absolute;top:6px;left:6px;z-index:2;width:18px;height:18px;cursor:pointer;">
        <a href="/uploads/<%= f.foto_path %>" target="_blank" rel="noopener">
          <img src="/uploads/<%= f.foto_path %>" alt="<%= f.didascalia || '' %>"
               style="width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:6px;border:1px solid var(--border);cursor:pointer;">
        </a>
        <p style="font-size:0.8rem;color:var(--text-muted);margin:0.3rem 0;"><%= f.didascalia || '' %><% if (f.evento_titolo) { %> — <%= f.evento_titolo %><% } %></p>
        <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
          <a href="/admin/galleria/<%= f.id %>/modifica" class="btn btn-sm btn-secondary">Modifica</a>
          <form method="POST" action="/admin/galleria/<%= f.id %>/elimina" onsubmit="return confirm('Eliminare foto?')" style="display:inline;">
            <button class="btn btn-sm btn-danger">Elimina</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</form>
<script>
  const cbs = document.querySelectorAll('.foto-cb');
  const btnEl = document.getElementById('btn-elimina-sel');
  const selTutto = document.getElementById('seleziona-tutto');
  function aggiornaBtn() {
    const n = document.querySelectorAll('.foto-cb:checked').length;
    btnEl.style.display = n > 0 ? 'inline-block' : 'none';
    btnEl.textContent = n > 0 ? 'Elimina selezionate (' + n + ')' : 'Elimina selezionate';
  }
  cbs.forEach(cb => cb.addEventListener('change', aggiornaBtn));
  selTutto.addEventListener('change', function() {
    cbs.forEach(cb => cb.checked = this.checked);
    aggiornaBtn();
  });
</script>
<% } %>
<%- include('../_footer') %>
