<%- include('../_header', { title, active }) %>
<div class="page-header">
  <h1>
    <% if (evento) { %>
      <a href="/admin/galleria" style="color:var(--text-muted);font-size:0.85rem;font-weight:400;">← Galleria</a>
      <span style="margin-left:0.5rem;"><%= evento.titolo %></span>
    <% } else { %>
      Galleria
    <% } %>
  </h1>
  <a href="/admin/galleria/nuovo" class="btn btn-primary">+ Aggiungi foto</a>
</div>

<% if (!evento) { %>
  <%/* ── INDICE EVENTI ── */%>
  <div class="gallery-grid">
    <% if (senzaEvento && senzaEvento.num_foto > 0) { %>
      <a href="/admin/galleria?evento=nessuno" style="text-decoration:none;color:inherit;">
        <div style="position:relative;border-radius:8px;overflow:hidden;border:1px solid var(--border);cursor:pointer;">
          <% if (senzaEvento.copertina) { %>
            <div style="width:100%;aspect-ratio:4/3;background:url('/uploads/<%= senzaEvento.copertina %>') center/cover;"></div>
          <% } else { %>
            <div style="width:100%;aspect-ratio:4/3;background:var(--bg-surface);display:flex;align-items:center;justify-content:center;font-size:2rem;">📷</div>
          <% } %>
          <div style="padding:0.8rem;">
            <div style="font-weight:700;">Foto senza evento</div>
            <div style="font-size:0.85rem;color:var(--text-muted);"><%= senzaEvento.num_foto %> foto</div>
          </div>
        </div>
      </a>
    <% } %>
    <% eventi.forEach(ev => { %>
      <a href="/admin/galleria?evento=<%= ev.id %>" style="text-decoration:none;color:inherit;">
        <div style="position:relative;border-radius:8px;overflow:hidden;border:1px solid var(--border);cursor:pointer;">
          <% if (ev.copertina) { %>
            <div style="width:100%;aspect-ratio:4/3;background:url('/uploads/<%= ev.copertina %>') center/cover;"></div>
          <% } else { %>
            <div style="width:100%;aspect-ratio:4/3;background:var(--bg-surface);display:flex;align-items:center;justify-content:center;font-size:2rem;">🎵</div>
          <% } %>
          <div style="padding:0.8rem;">
            <div style="font-weight:700;"><%= ev.titolo %></div>
            <div style="font-size:0.85rem;color:var(--text-muted);">
              <%= new Date(ev.data_evento).toLocaleDateString('it-IT', {day:'numeric',month:'long',year:'numeric'}) %>
              · <%= ev.num_foto %> foto
            </div>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
  <% if (eventi.length === 0 && (!senzaEvento || senzaEvento.num_foto === 0)) { %>
    <p style="color:var(--text-muted);">Nessuna foto. <a href="/admin/galleria/nuovo" style="color:var(--neon-purple);">Aggiungine una</a></p>
  <% } %>

<% } else { %>
  <%/* ── FOTO EVENTO ── */%>
  <% if (foto.length === 0) { %>
    <p style="color:var(--text-muted);">Nessuna foto per questo evento. <a href="/admin/galleria/nuovo" style="color:var(--neon-purple);">Aggiungine una</a></p>
  <% } else { %>
  <form method="POST" action="/admin/galleria/elimina-bulk" id="bulk-form">
    <input type="hidden" name="redirect" value="/admin/galleria?evento=<%= evento.id %>">
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
        <input type="checkbox" id="seleziona-tutto" style="width:auto;">
        <span style="font-size:0.9rem;">Seleziona tutte</span>
      </label>
      <button type="submit" class="btn btn-sm btn-danger" id="btn-elimina-sel"
              style="display:none;"
              onclick="return confirm('Eliminare le foto selezionate?')">
        Elimina selezionate
      </button>
    </div>
    <div class="gallery-grid">
      <% foto.forEach(f => { %>
        <div style="position:relative;">
          <input type="checkbox" name="ids" value="<%= f.id %>" class="foto-cb"
                 style="position:absolute;top:6px;left:6px;z-index:2;width:18px;height:18px;cursor:pointer;">
          <div style="width:100%;aspect-ratio:4/3;background:url('/uploads/<%= f.foto_path %>') center/cover;border-radius:6px;"></div>
          <p style="font-size:0.8rem;color:var(--text-muted);margin:0.3rem 0;"><%= f.didascalia || '' %></p>
          <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
            <a href="/admin/galleria/<%= f.id %>/modifica" class="btn btn-sm btn-secondary">Modifica</a>
            <button type="button" class="btn btn-sm btn-danger"
                    onclick="if(confirm('Eliminare foto?')) document.getElementById('del-<%= f.id %>').submit()">Elimina</button>
          </div>
        </div>
      <% }) %>
    </div>
  </form>
  <% foto.forEach(f => { %>
    <form id="del-<%= f.id %>" method="POST" action="/admin/galleria/<%= f.id %>/elimina" style="display:none;"></form>
  <% }) %>
  <script>
    const cbs = document.querySelectorAll('.foto-cb');
    const btnEl = document.getElementById('btn-elimina-sel');
    const selTutto = document.getElementById('seleziona-tutto');
    function aggiornaBtn() {
      const n = document.querySelectorAll('.foto-cb:checked').length;
      btnEl.style.display = n > 0 ? 'inline-block' : 'none';
      btnEl.textContent = 'Elimina selezionate (' + n + ')';
    }
    cbs.forEach(cb => cb.addEventListener('change', aggiornaBtn));
    selTutto.addEventListener('change', function() {
      cbs.forEach(cb => cb.checked = this.checked);
      aggiornaBtn();
    });
  </script>
  <% } %>
<% } %>
<%- include('../_footer') %>
