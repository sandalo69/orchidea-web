<%- include('../_header', { title, active }) %>
<div class="page-header">
  <h1>Gestione eventi</h1>
  <a href="/admin/eventi/nuovo" class="btn btn-primary">+ Nuovo evento</a>
</div>
<% if (eventi.length === 0) { %>
  <div class="card" style="text-align:center;padding:3rem;color:var(--text-muted);">Nessun evento. <a href="/admin/eventi/nuovo" style="color:var(--neon-purple);">Crea il primo</a></div>
<% } else { %>
  <div class="card" style="padding:0;">
    <table>
      <thead><tr><th>Titolo</th><th>Data</th><th>Stato</th><th>Prenotazioni</th><th>Azioni</th></tr></thead>
      <tbody>
        <% eventi.forEach(ev => { %>
          <tr>
            <td><strong><%= ev.titolo %></strong><% if (ev.layout_nome) { %><br><small style="color:var(--text-muted);"><%= ev.layout_nome %></small><% } %></td>
            <td><%= new Date(ev.data_evento).toLocaleDateString('it-IT') %></td>
            <td><span class="badge <%= ev.pubblicato ? 'badge-green' : 'badge-gray' %>"><%= ev.pubblicato ? 'Pubblicato' : 'Bozza' %></span></td>
            <td><span class="badge <%= ev.prenotazioni_aperte ? 'badge-green' : 'badge-gray' %>"><%= ev.prenotazioni_aperte ? 'Aperte' : 'Chiuse' %></span></td>
            <td style="display:flex;gap:0.5rem;align-items:center;">
              <a href="/admin/eventi/<%= ev.id %>/modifica" class="btn btn-sm btn-secondary">Modifica</a>
              <form method="POST" action="/admin/eventi/<%= ev.id %>/elimina" onsubmit="return confirm('Eliminare questo evento?')">
                <button class="btn btn-sm btn-danger">Elimina</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
<%- include('../_footer') %>
