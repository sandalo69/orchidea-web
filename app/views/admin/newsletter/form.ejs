<%- include('../_header', { title, active }) %>
<div class="page-header">
  <h1>Invia Newsletter</h1>
</div>
<% if (query.success === 'inviata') { %>
  <div class="alert alert-success">✓ Newsletter inviata a <%= query.count %> iscritti.</div>
<% } else if (query.error) { %>
  <div class="alert alert-error">Errore durante l'invio.</div>
<% } %>
<div class="card" style="max-width:700px;">
  <form method="POST" action="/admin/newsletter">
    <div class="form-group">
      <label>Oggetto *</label>
      <input type="text" name="oggetto" required placeholder="Oggetto della email">
    </div>
    <div class="form-group">
      <label>Corpo (HTML o testo)</label>
      <textarea name="corpo" required style="min-height:250px;font-family:monospace;" placeholder="<h1>Ciao!</h1><p>Testo della newsletter...</p>"></textarea>
    </div>
    <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1rem;">La newsletter verrà inviata a tutti gli utenti con account confermato.</p>
    <button type="submit" class="btn btn-primary" onclick="return confirm('Inviare la newsletter?')">Invia newsletter</button>
  </form>
</div>
<%- include('../_footer') %>
