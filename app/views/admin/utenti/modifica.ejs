<%- include('../_header', { title, active }) %>
<div class="page-header">
  <h1>Modifica utente</h1>
  <a href="/admin/utenti" class="btn btn-secondary">← Indietro</a>
</div>
<% if (success) { %>
  <div class="alert-success" style="margin-bottom:1.5rem;">Modifiche salvate.</div>
<% } %>
<div class="card" style="max-width:560px;">
  <form method="POST" action="/admin/utenti/<%= utente.id %>">
    <div class="form-group">
      <label>Nome</label>
      <input type="text" name="nome" value="<%= utente.nome %>" required maxlength="100">
    </div>
    <div class="form-group">
      <label>Cognome</label>
      <input type="text" name="cognome" value="<%= utente.cognome %>" required maxlength="100">
    </div>
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" value="<%= utente.email %>" required maxlength="255">
    </div>
    <div class="form-group">
      <label>Telefono</label>
      <input type="text" name="telefono" value="<%= utente.telefono %>" maxlength="20">
    </div>
    <div class="form-group" style="display:flex;align-items:center;gap:0.75rem;">
      <input type="checkbox" name="confermato" id="confermato" <%= utente.confermato ? 'checked' : '' %> style="width:auto;">
      <label for="confermato" style="margin:0;">Account confermato</label>
    </div>
    <div class="form-group">
      <label>Nuova password <span style="font-weight:400;font-size:0.8rem;color:var(--text-muted);">(lascia vuoto per non modificare, min. 6 caratteri)</span></label>
      <input type="password" name="password" maxlength="255" autocomplete="new-password">
    </div>
    <button type="submit" class="btn btn-primary">Salva modifiche</button>
  </form>
</div>
<div class="card" style="max-width:560px;margin-top:1.5rem;border-color:var(--neon-fuchsia);">
  <h3 style="color:var(--neon-fuchsia);margin-bottom:1rem;">Zona pericolosa</h3>
  <form method="POST" action="/admin/utenti/<%= utente.id %>/elimina"
        onsubmit="return confirm('Eliminare <%= utente.nome %> <%= utente.cognome %>? Verranno cancellate anche le sue prenotazioni.')">
    <button type="submit" class="btn" style="background:var(--neon-fuchsia);color:#fff;">Elimina utente</button>
  </form>
</div>
<%- include('../_footer') %>
