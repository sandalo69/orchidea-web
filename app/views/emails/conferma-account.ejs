<!DOCTYPE html>
<html lang="it">
<head><meta charset="UTF-8"><title>Conferma account</title></head>
<body style="background:#0a0a0f;color:#e0e0e0;font-family:sans-serif;padding:2rem;">
  <div style="max-width:500px;margin:0 auto;background:#13131f;border:1px solid rgba(157,0,255,0.3);border-radius:8px;padding:2rem;">
    <h1 style="background:linear-gradient(135deg,#9d00ff,#ff00e4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 1rem;">
      🌸 Orchidea
    </h1>
    <p>Ciao <strong><%= nome %></strong>,</p>
    <p style="margin:1rem 0;">Clicca il link per confermare il tuo account:</p>
    <a href="<%= link %>" style="display:inline-block;padding:0.8rem 2rem;background:#9d00ff;color:white;text-decoration:none;border-radius:4px;font-weight:700;">
      Conferma Account
    </a>
    <p style="margin-top:1.5rem;color:#888;font-size:0.85rem;">Il link scade in 24 ore.</p>
  </div>
</body>
</html>
